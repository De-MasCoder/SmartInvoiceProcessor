{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "<set-in-release-pipeline>"
  },
  "Blob": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "uploads"
  },
  "ServiceBus": {
    "ConnectionString": "<your-connection>",
    "QueueName": "documents"
  }
}
